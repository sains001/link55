<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>55Five Prediction Dashboard</title>
    <style>
        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; background: #121212; font-family: 'Segoe UI', sans-serif; color: white; }
        
        /* Login Overlay */
        #login-overlay { position: fixed; top:0; left:0; width:100%; height:100%; background:#121212; z-index:999; display:flex; flex-direction:column; align-items:center; justify-content:center; }
        .login-card { background:#1a1a1a; padding:20px; border-radius:10px; border:1px solid #333; width:280px; text-align:center; }
        input { width:100%; padding:10px; margin:10px 0; border-radius:5px; border:1px solid #333; background:#222; color:white; box-sizing:border-box; }
        button { width:100%; padding:10px; background:#ff4444; border:none; color:white; font-weight:bold; cursor:pointer; border-radius:5px; }

        /* Layout Split 35/65 */
        #top-panel { height: 35vh; width: 100%; padding: 10px; box-sizing: border-box; border-bottom: 2px solid #ff4444; background: #1a1a1a; overflow-y: auto; }
        #bottom-panel { height: 65vh; width: 100%; background: #000; }
        iframe { width: 100%; height: 100%; border: none; }

        /* Tabel Styling */
        table { width: 100%; border-collapse: collapse; margin-top: 5px; table-layout: fixed; }
        th { background: #333; color: #888; font-size: 10px; padding: 6px; text-transform: uppercase; }
        td { padding: 8px; text-align: center; border-bottom: 1px solid #2a2a2a; font-size: 12px; font-weight: bold; }
        
        /* Status & Warna */
        .win { color: #00ff00; background: rgba(0, 255, 0, 0.05); }
        .lose { color: #ff4444; background: rgba(255, 68, 68, 0.05); }
        .timer { color: #ffeb3b; font-family: monospace; font-size: 16px; }
        .period { color: #03a9f4; }
        .running { font-style: italic; color: #ff9800; }
    </style>
</head>
<body>

<!-- Login Section -->
<div id="login-overlay">
    <div class="login-card">
        <h3>User Login</h3>
        <input type="text" id="username" placeholder="Username">
        <input type="password" id="password" placeholder="Password">
        <button onclick="handleLogin()">MASUK</button>
        <p id="login-err" style="color:red; font-size:12px; margin-top:10px;"></p>
    </div>
</div>

<div id="main-content" style="display:none;">
    <div id="top-panel">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
            <div id="status" style="font-size: 11px; color: #666;">Menunggu Detik 01/31...</div>
            <div style="font-size: 12px;">Prediksi: <span id="next-guess" style="color: #ffeb3b;">---</span></div>
        </div>
        
        <table>
            <thead>
                <tr>
                    <th width="20%">Periode</th>
                    <th width="20%">Prediksi</th>
                    <th width="15%">Count</th>
                    <th width="25%">Hasil</th>
                    <th width="20%">Status</th>
                </tr>
            </thead>
            <tbody id="table-body"></tbody>
        </table>
    </div>

    <div id="bottom-panel">
        <iframe src="https://55x4mqd.com"></iframe>
    </div>
</div>

<script>
    // --- KONFIGURASI ---
    const AUTH_HEADER = "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..gSi3-FxVwLXKTA1drTBTrA6HqiASn6eBkmsWMyW2HP0";
    const GITHUB_USER_JSON = "https://raw.githubusercontent.com";
    const PROXY = "https://corsproxy.io";
    const API_URL = "https://newapi.55lottertttapi.com/api/webapi/GetNoaverageEmerdList";
    
    let history = [];
    let currentPrediction = "BESAR";
    let isLocked = false;

    // --- LOGIKA LOGIN ---
    async function handleLogin() {
        const u = document.getElementById('username').value;
        const p = document.getElementById('password').value;
        const err = document.getElementById('login-err');

        try {
            const resp = await fetch(GITHUB_USER_JSON);
            const users = await resp.json();
            const found = users.find(user => user.username === u && user.password === p);

            if(found) {
                document.getElementById('login-overlay').style.display = 'none';
                document.getElementById('main-content').style.display = 'block';
                startEngine();
            } else {
                err.innerText = "Login Gagal!";
            }
        } catch(e) {
            err.innerText = "Error memuat database user.";
        }
    }

    // --- LOGIKA PREDIKSI ---
    function startEngine() {
        render();
        generatePrediction();
        setInterval(() => {
            const now = new Date();
            const sec = now.getSeconds();
            let count = (sec < 30) ? (30 - sec) : (60 - sec);
            
            const live = document.getElementById('live-count');
            if (live) live.innerText = count + "s";

            if ((sec === 1 || sec === 31) && !isLocked) {
                isLocked = true;
                fetchResult();
            }
            if (sec === 3 || sec === 33) {
                isLocked = false;
                generatePrediction();
            }
        }, 1000);
    }

    async function fetchResult() {
        document.getElementById('status').innerText = "Mengecek Hasil...";
        try {
            const response = await fetch(PROXY + encodeURIComponent(API_URL), {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json; charset=UTF-8',
                    'Authorization': AUTH_HEADER 
                },
                body: JSON.stringify({
                    "pageSize": 10, "pageNo": 1, "typeId": 30, "language": 0,
                    "random": "b631eb26", "signature": "A6203E85", "timestamp": Date.now()
                })
            });

            const res = await response.json();
            const latest = res.data.list[0];
            
            const period = latest.issueNumber.toString().slice(-5);
            const num = parseInt(latest.number.split(",").pop());
            const cat = num >= 5 ? "BESAR" : "KECIL";
            const status = (currentPrediction === cat) ? "WIN" : "LOSE";

            history.unshift({ period, pred: currentPrediction, num, cat, stat: status });
            if (history.length > 6) history.pop();
            render();
            document.getElementById('status').innerText = "Update Berhasil";
        } catch (e) {
            document.getElementById('status').innerText = "TOKEN EXPIRED / ERROR";
        }
    }

    function generatePrediction() {
        currentPrediction = Math.random() > 0.5 ? "BESAR" : "KECIL";
        document.getElementById('next-guess').innerText = currentPrediction;
        render();
    }

    function render() {
        const tbody = document.getElementById('table-body');
        let html = `<tr>
            <td class="period running">Next</td>
            <td>${currentPrediction}</td>
            <td class="timer" id="live-count">--s</td>
            <td>--</td>
            <td style="color:#666;">WAIT</td>
        </tr>`;

        history.forEach(item => {
            html += `<tr class="${item.stat.toLowerCase()}">
                <td class="period">${item.period}</td>
                <td>${item.pred}</td>
                <td>0s</td>
                <td>${item.cat} (${item.num})</td>
                <td>${item.stat}</td>
            </tr>`;
        });
        tbody.innerHTML = html;
    }
</script>
</body>
</html>
